      <li>\uc0\u12431 \u12374 \u12431 \u12374 \u12362 \u21270 \u31911 \u12434 \u12375 \u12390 \u12289 \u30528 \u26367 \u12360 \u12390 \u12289 \u12461 \u12521 \u12461 \u12521 \u12375 \u12383 \u31354 \u38291 \u12395 \u36890 \u12358 \u12398 \u12364 \u38754 \u20498 \u12367 \u12373 \u12356 </li>\
      <li>\uc0\u36942 \u21435 \u12395 \u12363 \u12425 \u12363 \u12431 \u12428 \u12383 \u12488 \u12521 \u12454 \u12510 \u12364 \u12354 \u12426 \u12289 \u20154 \u21069 \u12391 \u36939 \u21205 \u12377 \u12427 \u12398 \u12364 \u24598 \u12356 </li>\
