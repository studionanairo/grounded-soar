    <p>\uc0\u12371 \u12435 \u12395 \u12385 \u12399 \u12290 \u35370 \u21839 \u22411 \u12503 \u12521 \u12452 \u12505 \u12540 \u12488 \u12539 \u12500 \u12521 \u12486 \u12451 \u12473 \u65286 \u12520 \u12460 \u12300 Grounded Soar\u65288 \u12464 \u12521 \u12454 \u12531 \u12487 \u12483 \u12489 \u12539 \u12477 \u12450 \u65289 \u12301 \u20027 \u23472 \u12398 \u12289 Nanairo\u12392 \u30003 \u12375 \u12414 \u12377 \u12290 </p>\
    <p>40\uc0\u20195 \u12434 \u36814 \u12360 \u12289 \u20307 \u21147 \u12398 \u34928 \u12360 \u12420 \u20307 \u22411 \u12398 \u22793 \u21270 \u12434 \u24863 \u12376 \u12427 \u26085 \u12293 \u12290 \u12300 \u20581 \u24247 \u12398 \u12383 \u12417 \u12395 \u36939 \u21205 \u12434 \u22987 \u12417 \u12394 \u12365 \u12419 \u12301 \u12392 \u38957 \u12391 \u12399 \u12431 \u12363 \u12387 \u12390 \u12356 \u12427 \u12398 \u12395 \u12289 \u12356 \u12374 \u12420 \u12429 \u12358 \u12392 \u12377 \u12427 \u12392 \u12289 \u12393 \u12358 \u12375 \u12390 \u12418 \u36275 \u12364 \u37325 \u12367 \u12394 \u12387 \u12390 \u12375 \u12414 \u12358 \u12371 \u12392 \u12399 \u12354 \u12426 \u12414 \u12379 \u12435 \u12363 \u65311 </p>\
    <ul>\
